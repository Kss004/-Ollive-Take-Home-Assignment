{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Requests / sec",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(llm_inference_total[1m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Error rate",
      "id": 2,
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(llm_inference_total{status=\"error\"}[5m])) / clamp_min(sum(rate(llm_inference_total[5m])), 1e-9)",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "DLQ events (5m)",
      "id": 3,
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(increase(llm_ingest_dlq_total[5m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Processed (total)",
      "id": 4,
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(llm_ingest_processed_total)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (s) by provider",
      "id": 5,
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, provider) (rate(llm_inference_latency_seconds_bucket[5m])))",
          "legendFormat": "p50 {{provider}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(llm_inference_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{provider}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, provider) (rate(llm_inference_latency_seconds_bucket[5m])))",
          "legendFormat": "p99 {{provider}}",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "TTFT p95 (s) by provider+model",
      "id": 6,
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider, model) (rate(llm_inference_ttft_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} / {{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Throughput by status",
      "id": 7,
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status) (rate(llm_inference_total[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Token rate (prompt vs completion) by provider",
      "id": 8,
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (kind, provider) (rate(llm_inference_tokens_total[1m]))",
          "legendFormat": "{{provider}} {{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["ollive", "llm"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
