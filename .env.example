# Copy to .env and fill in values. At least one provider key required.

# ---- LLM provider keys ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ---- Postgres ----
POSTGRES_USER=ollive
POSTGRES_PASSWORD=ollive
POSTGRES_DB=ollive
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ollive:ollive@postgres:5432/ollive

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Service URLs (inside compose network) ----
CHAT_API_URL=http://chat-api:8000
INGESTION_URL=http://ingestion:8001

# ---- Public origins (browser side) ----
NEXT_PUBLIC_CHAT_API_URL=http://localhost:8000

# ---- Ingestion ----
INFERENCE_STREAM=inference:logs
INFERENCE_DLQ=inference:logs:dlq
INFERENCE_GROUP=ingest
INFERENCE_CONSUMER=worker-1

# ---- Defaults ----
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini

# ---- Grafana ----
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
